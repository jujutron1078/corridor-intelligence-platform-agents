# ─── LLM / Agent ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=...
TAVILY_API_KEY=...

# ─── Pipeline data sources ───────────────────────────────────────────────────
GEE_PROJECT=your-gee-project-id
COMTRADE_API_KEY=...
ACLED_API_KEY=...
ACLED_EMAIL=you@example.com
ACLED_USERNAME=you@example.com
ACLED_PASSWORD=...

# ─── Observability ───────────────────────────────────────────────────────────
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=corridor_intelligence
LOG_FORMAT=json

# ─── Infrastructure ──────────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379
DATABASE_URI=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_DOCS=true
SCHEDULER_ENABLED=true
CACHE_TTL_SECONDS=3600

# ─── Data root ───────────────────────────────────────────────────────────────
# Absolute path where pipeline artifacts live. Defaults to <repo>/data in dev.
# In prod this is a mounted volume hydrated from the R2 data bucket.
# CORRIDOR_DATA_ROOT=/data

# ─── Security (REQUIRED in prod, empty = dev bypass) ─────────────────────────
# 32+ random hex chars. Rotate by running: openssl rand -hex 32
BACKEND_API_KEY=
# Comma-separated. No wildcards in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# slowapi rate limits: "N/period" where period is second|minute|hour|day
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_DEFAULT=120/minute

# ─── Model routing (optional overrides) ──────────────────────────────────────
# ROUTE_CHAT_AGENT=gpt-4o
# ROUTE_REPORT=gpt-4o
